From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: OpenCode <opencode@example.com>
Date: Tue, 28 Apr 2026 00:00:00 +0000
Subject: [PATCH] axum-server: add body data Buf bound

The locked hyper-util version requires upgraded HTTP/2 body data to implement
bytes::Buf. axum-server 0.6.0's generic server bound omits that associated-type
constraint, which fails to compile with the current dependency set.

Patch a local path copy instead of the checksummed cargo-vendored registry
directory.

---
 Cargo.toml                                | 3 +++
 patched-crates/axum-server/src/server.rs | 2 ++
 2 files changed, 5 insertions(+)

diff --git a/Cargo.toml b/Cargo.toml
index 9d29b5e..f4bd88c 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -142,6 +142,9 @@ hwencode = ["hwcodec", "libyuv", "turbojpeg"]
 v4l2 = ["v4l2r"]
 aml = ["hwcodec/aml"]
 
+[patch.crates-io]
+axum-server = { path = "patched-crates/axum-server" }
+
 [profile.release]
 opt-level = 3
 lto = true
diff --git a/patched-crates/axum-server/src/server.rs b/patched-crates/axum-server/src/server.rs
index aa0e3ff..8b2b8cf 100644
--- a/patched-crates/axum-server/src/server.rs
+++ b/patched-crates/axum-server/src/server.rs
@@ -4,6 +4,7 @@ use crate::{
     service::TowerToHyperService,
     service::{MakeService, SendService},
 };
+use bytes::Buf;
 use futures_util::future::poll_fn;
 use http::Request;
 use hyper::body::Incoming;
@@ -156,6 +157,7 @@ where
         A: Accept<TcpStream, M::Service> + Clone + Send + Sync + 'static,
         A::Stream: AsyncRead + AsyncWrite + Unpin + Send,
         A::Service: SendService<Request<Incoming>> + Send,
+        <A::Service as SendService<Request<Incoming>>>::BodyData: Buf,
         A::Future: Send,
     {
         let acceptor = self.acceptor;
-- 
