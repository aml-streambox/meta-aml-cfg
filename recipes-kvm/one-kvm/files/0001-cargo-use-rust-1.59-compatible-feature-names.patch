From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: OpenCode <opencode@example.com>
Date: Tue, 28 Apr 2026 00:00:00 +0000
Subject: [PATCH] cargo: use Rust 1.59-compatible feature names

Yocto kirkstone carries Rust/Cargo 1.59, which rejects `dep:`
namespaced feature syntax. Use the implicit optional dependency feature
names instead so the same feature sets work with Cargo 1.59.

---
 Cargo.toml | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/Cargo.toml b/Cargo.toml
index 13f24d2..9d29b5e 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -137,8 +137,8 @@ toml = "0.8"
 
 [features]
 default = ["hwencode", "v4l2"]
-hwencode = ["dep:hwcodec", "dep:libyuv", "dep:turbojpeg"]
-v4l2 = ["dep:v4l2r"]
+hwencode = ["hwcodec", "libyuv", "turbojpeg"]
+v4l2 = ["v4l2r"]
 aml = ["hwcodec/aml"]
 
 [profile.release]
-- 
2.34.1
